// weld-board 数据模型 —— 这就是"单一真源"。
// 本地用 SQLite;部署到 Neon 时把 provider 改成 "postgresql"(模型无需改)。
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id           String     @id @default(cuid())
  slug         String     @unique
  name         String
  lastSyncedAt DateTime?
  techStack    String     @default("") // 顶部钉住的"当前约定技术栈"(markdown)
  modules      Module[]
  edges        ModuleEdge[]
  users        User[]
  features     Feature[]
  decisions    Decision[]
}

// 模块 = 脊梁。人/功能/决策都按 moduleKey 挂到它上面。
model Module {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key       String
  title     String
  summary   String   @default("")
  boundary  String   @default("") // 边界说明:这个模块负责什么 / 不负责什么
  ownerName String? // 负责人名字(与 User.name 匹配后取其高亮色)
  doc       String   @default("") // 完整文档(markdown),展示在模块单页
  functions String   @default("[]") // 函数级条目 JSON: [{name, note}]
  posX      Float    @default(0)
  posY      Float    @default(0)
  edgesOut  ModuleEdge[] @relation("edgeFrom")
  edgesIn   ModuleEdge[] @relation("edgeTo")

  @@unique([projectId, key])
}

model ModuleEdge {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromId    String
  toId      String
  kind      String  @default("depends") // depends | boundary
  from      Module  @relation("edgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        Module  @relation("edgeTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, kind])
}

model User {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  color       String // 高亮色 hex
  githubLogin String? // 预留,以后接 OAuth
  presence    Presence?

  @@unique([projectId, name])
}

// 谁在做什么
model Presence {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentTask String   @default("")
  moduleKey   String? // 挂在哪个模块
  updatedAt   DateTime @updatedAt
}

// 产品功能
model Feature {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  status    String  @default("todo") // todo | doing | done
  moduleKey String?
  ownerName String?
  body      String  @default("")

  @@unique([projectId, title])
}

// 技术决策 / ADR(= 统一技术方案)
model Decision {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  status    String    @default("accepted") // proposed | accepted | superseded
  moduleKey String?
  body      String    @default("") // markdown
  decidedAt DateTime?

  @@unique([projectId, title])
}
