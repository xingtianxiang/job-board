// weld-board 数据模型 —— 这就是"单一真源"。
// 数据库:Neon Postgres(本地与线上同一种)。
// 想纯本地离线开发可临时把 provider 改回 "sqlite" 并用 DATABASE_URL="file:./dev.db"。
generator client {
  provider      = "prisma-client-js"
  // native = 本地;rhel-openssl-3.0.x = Vercel(serverless)运行时所需的 Linux 引擎
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id           String     @id @default(cuid())
  slug         String     @unique
  name         String
  lastSyncedAt DateTime?
  techStack    String     @default("") // 顶部钉住的"当前约定技术栈"(markdown)
  modules      Module[]
  edges        ModuleEdge[]
  users        User[]
  features     Feature[]
  decisions    Decision[]
  commits      Commit[]
  activeBranches ActiveBranch[]
}

// 模块 = 脊梁。人/功能/决策都按 moduleKey 挂到它上面。
model Module {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key       String
  title     String
  summary   String   @default("")
  boundary  String   @default("") // 边界说明:这个模块负责什么 / 不负责什么
  ownerName String? // 负责人名字(与 User.name 匹配后取其高亮色)
  doc       String   @default("") // 完整文档(markdown),展示在模块单页
  functions String   @default("[]") // 函数级条目 JSON: [{name, note}]
  paths     String   @default("[]") // 该模块对应的代码路径 glob(JSON)
  activeUsers String @default("[]") // 正在改这个模块的人:JSON [{name, at(ISO)}];sync 按 git 改动增量维护,支持多人
  posX      Float    @default(0)
  posY      Float    @default(0)
  edgesOut  ModuleEdge[] @relation("edgeFrom")
  edgesIn   ModuleEdge[] @relation("edgeTo")

  @@unique([projectId, key])
}

model ModuleEdge {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromId    String
  toId      String
  kind      String  @default("depends") // depends | boundary
  from      Module  @relation("edgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        Module  @relation("edgeTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, kind])
}

model User {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  color       String // 高亮色 hex
  gitEmail    String? // git config user.email:把 sync 的 git 身份稳定地认到成员(比 name 稳);sync 时自动学习,匹配优先于 name
  githubLogin String? // 预留,以后接 OAuth
  presence    Presence?

  @@unique([projectId, name])
}

// 谁在做什么
model Presence {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentTask String   @default("")
  moduleKey   String? // 挂在哪个模块
  updatedAt   DateTime @updatedAt
}

// 产品功能
model Feature {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  status    String  @default("todo") // todo | doing | done
  moduleKey String?
  ownerName String?
  body      String  @default("")
  archived  Boolean @default(false) // 完成项归档:不在主看板显示,移到 /archive

  @@unique([projectId, title])
}

// 技术决策 / ADR(= 统一技术方案)
model Decision {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  status    String    @default("accepted") // proposed | accepted | superseded
  moduleKey String?
  body      String    @default("") // markdown
  decidedAt DateTime?

  @@unique([projectId, title])
}

// ───────────────────────────────────────────────────────────────────────────
// 历史车道(additive history lane)—— 与"✎ 实时在改"信号四不沾:
// 独立的表、独立的 endpoint(/api/github-ingest)、独立的 handler、独立的 token。
// 数据由 GitHub Action(push 时)推入,绝不触碰 Module.activeUsers。
// ───────────────────────────────────────────────────────────────────────────

// 一条 git 提交。按 (projectId, sha) 幂等;重推自愈。
model Commit {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sha         String // 全 40 位,幂等键
  shortSha    String       @default("")
  branch      String       @default("")
  message     String       @default("") // 只存首行
  authorName  String       @default("")
  authorEmail String       @default("")
  authorLogin String? // 对应 User.githubLogin,用来上色
  committedAt DateTime // 时间维度
  moduleKeys  String       @default("[]") // 命中的模块 key,JSON 存 String(随大流)
  files       CommitFile[]
  createdAt   DateTime     @default(now())

  @@unique([projectId, sha])
  @@index([projectId, committedAt])
}

// 一条提交里改动的单个文件路径(正斜杠归一)。重推时 delete+recreate。
model CommitFile {
  id       String @id @default(cuid())
  commitId String
  commit   Commit @relation(fields: [commitId], references: [id], onDelete: Cascade)
  path     String

  @@index([commitId])
}

// ───────────────────────────────────────────────────────────────────────────
// 活跃分支雷达 —— 驱动"提交/分支在改"点灯(①提交衰减 + ②分支/合并真相)。
// 与 Module.activeUsers(旧 diff 信号)、Commit(历史车道)【三不沾】:独立表、
// 独立端点(/api/branch-activity)、由 GitHub Action 喂数(push/PR-merged/delete)。
// 一条"领先 main、最近还在动"的分支 = 一行;PR 合并 / 远端删除 → 删行(立刻灭);
// lastActivityAt 超过窗口未动 → 读取端不再点亮(漏事件兜底)。
// ───────────────────────────────────────────────────────────────────────────
model ActiveBranch {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name           String // 分支名(如 feat/merge-robot-executor)
  authorName     String   @default("")
  authorEmail    String   @default("") // 按 email 认看板成员(与既有逻辑一致)→ 取其画布色
  moduleKeys     String   @default("[]") // 该分支当前碰到的模块 key(JSON);由"领先 main 的文件"经 fileMatchesPaths 算出
  lastActivityAt DateTime // 该分支最新提交时间 → ① 衰减 / 僵尸分支兜底
  updatedAt      DateTime @updatedAt

  @@unique([projectId, name])
  @@index([projectId, lastActivityAt])
}
