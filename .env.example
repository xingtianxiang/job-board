# ---- 数据库:Neon Postgres(本地与线上同一种)----
# 在 https://neon.tech 建免费库,把连接串填这里:
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
#
# ⚠ 一次性 backfill(几百条 commit)前(§5 坑1):裸连接串会在批量 upsert 时打爆 Neon 连接/超时。
#   二选一:(a) 换成 Neon 的 pooled 端点并加 directUrl 给 db push:
#     DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/DB?sslmode=require&pgbouncer=true&connection_limit=1"
#     DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"   # 并在 schema.prisma 的 datasource 加 directUrl = env("DIRECT_URL")
#   (b) 不改连接串:让 backfill 每批 ~50 条、严格串行(applyGithubCommits 已是逐条 await,稳态推一条无虞)。

# 本地 board-sync 上传看板数据时携带的令牌(本地 .env 与线上 Vercel 必须一致)
BOARD_INGEST_TOKEN="change-me-to-a-long-random-string"

# 历史车道:GitHub Action 推提交历史时携带的令牌(与 BOARD_INGEST_TOKEN【独立】)。
# 线上 Vercel 环境变量 + weld_KAIERDA 仓库 secret 要填同一个值。
GITHUB_INGEST_TOKEN="change-me-to-another-long-random-string"

# 可选:整站团队口令。留空则不启用门槛。
TEAM_PASSCODE=""

# ---- 想纯本地离线开发(不连 Neon)? ----
# 1) 把 prisma/schema.prisma 的 datasource provider 改回 "sqlite"
# 2) DATABASE_URL="file:./dev.db"
# 3) npm run db:push
