# ---- 本地开发(SQLite,零配置) ----
DATABASE_URL="file:./dev.db"

# ---- 部署到 Vercel 时,改用 Neon Postgres ----
# 1) 在 prisma/schema.prisma 把 datasource provider 改成 "postgresql"
# 2) DATABASE_URL 填 Neon 的连接串,例如:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# 本地 board-sync 上传看板数据时携带的令牌(本地与服务端必须一致)
BOARD_INGEST_TOKEN="change-me-to-a-long-random-string"

# 可选:整站团队口令。留空则不启用门槛。
TEAM_PASSCODE=""
