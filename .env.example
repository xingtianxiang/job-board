# ---- 数据库:Neon Postgres(本地与线上同一种)----
# 在 https://neon.tech 建免费库,把连接串填这里:
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# 本地 board-sync 上传看板数据时携带的令牌(本地 .env 与线上 Vercel 必须一致)
BOARD_INGEST_TOKEN="change-me-to-a-long-random-string"

# 可选:整站团队口令。留空则不启用门槛。
TEAM_PASSCODE=""

# ---- 想纯本地离线开发(不连 Neon)? ----
# 1) 把 prisma/schema.prisma 的 datasource provider 改回 "sqlite"
# 2) DATABASE_URL="file:./dev.db"
# 3) npm run db:push
